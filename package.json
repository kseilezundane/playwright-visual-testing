  },
  "packageManager": "yarn@4.12.0",
  "resolutions": {
    "playwright-core@npm:1.60.0": "patch:playwright-core@npm%3A1.60.0#~/.yarn/patches/playwright-core-npm-1.60.0-3d53a7d2d6.patch"
